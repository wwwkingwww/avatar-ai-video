# DeepSeek API 配置
DEEPSEEK_URL=https://api.deepseek.com
DEEPSEEK_KEY=your-deepseek-api-key-here

# 数据库配置
DATABASE_URL=postgresql://localhost:5432/avatar_ai_video?schema=public

# 服务器端口
PORT=3099

# 调试模式（开发环境可设为 true，生产环境设为 false）
DEBUG=true

# 管理员认证
# ADMIN_PASSWORD=your-admin-password
# ADMIN_JWT_SECRET=your-jwt-secret

# Redis（BullMQ 队列）
# REDIS_URL=redis://localhost:6379

# MQTT
# MQTT_BROKER=mqtt://localhost:1883

# MinIO 对象存储
# MINIO_ENDPOINT=http://localhost:9000
# MINIO_ACCESS_KEY=your-minio-access-key
# MINIO_SECRET_KEY=your-minio-secret-key
# MINIO_BUCKET=creator-uploads

# 默认模型配置（可选，不设置则使用内置默认值）
# DEFAULT_IMAGE_TO_VIDEO_MODEL=rhart-video/ltx-2.3/image-to-video
# DEFAULT_TEXT_TO_VIDEO_MODEL=rhart-video/ltx-2.3/text-to-video

# 最大重试次数（默认 3）
# MAX_RETRY_COUNT=3

# 日志级别：debug | info | warn | error（默认 info）
# LOG_LEVEL=info
