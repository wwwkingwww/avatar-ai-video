{
  "name": "runninghub-gen",
  "version": "2.0.0",
  "description": "调用 RunningHub V2 API 生成 AI 视频 (Bearer Token)",
  "entry": "generate.js",
  "parameters": {
    "endpoint": { "type": "string", "required": true, "description": "V2 API 模型端点路径" },
    "payload": { "type": "object", "required": true, "description": "模型参数" },
    "apiKey": { "type": "string", "required": false, "description": "API Key (默认取环境变量 RH_API_KEY)" },
    "files": { "type": "object", "required": false, "description": "上传文件 {fieldKey: [{buffer, name}]}" },
    "timeout": { "type": "number", "default": 600000, "description": "超时 (ms)" }
  }
}
